<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="parentContainer" alignment="TOP_CENTER" prefHeight="700.0" prefWidth="420.0" 
      style="-fx-background-color: #F1F5F9;" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="anagno.controller.DeliveryController">
    
    <stylesheets>
        <URL value="@login.css" />
    </stylesheets>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15 20 0 0;">
        <Button onAction="#handleMinimize" styleClass="window-control-button" text="—" />
        <Button onAction="#handleClose" styleClass="window-control-button, close-button" text="✕" />
    </HBox>

    <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 10 30 30 30;">
        <children>
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label text="COURIER PORTAL" style="-fx-text-fill: #6366F1; -fx-font-size: 10; -fx-letter-spacing: 1.5px; -fx-font-weight: bold;" />
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="studentNameLabel" text="Delivery Dashboard" style="-fx-text-fill: #1E293B; -fx-font-size: 22; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#refreshJobs" text="↻" 
                                style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-font-size: 16; -fx-cursor: hand; -fx-pref-width: 40;" />
                    </children>
                </HBox>
            </VBox>

            <VBox spacing="15" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white; 
                         -fx-background-radius: 16; 
                         -fx-border-color: #E2E8F0; 
                         -fx-border-width: 1; 
                         -fx-border-radius: 16; 
                         -fx-padding: 20; 
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <children>
                    <Label text="ACTIVE ASSIGNMENTS" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;" />

                    <TableView fx:id="deliveryTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colFood" prefWidth="150" text="ORDER ITEM" />
                            <TableColumn fx:id="colLocation" prefWidth="100" text="DROP-OFF" />
                            <TableColumn fx:id="colStatus" prefWidth="80" text="STATUS" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <VBox spacing="10">
                        <Button onAction="#handleStartDelivery" maxWidth="Infinity" prefHeight="50" 
                                style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" 
                                text="CONFIRM PICKUP" />
                        
                        <Button onAction="#handleConfirmArrived" maxWidth="Infinity" prefHeight="48" 
                                style="-fx-background-color: transparent; -fx-border-color: #10B981; -fx-text-fill: #10B981; -fx-font-weight: bold; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" 
                                text="MARK AS DELIVERED" />
                    </VBox>
                </children>
            </VBox>

            <HBox alignment="CENTER" spacing="5">
                <children>
                    <Button onAction="#handleOpenSettings" 
                            style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-size: 11; -fx-cursor: hand;" 
                            text="⚙ Account Profile Settings" />
                </children>
            </HBox>

            <Button onAction="#handleLogout" maxWidth="Infinity" prefHeight="45.0" 
                    style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" 
                    text="LOGOUT" />
        </children>
    </VBox>

    <HBox alignment="CENTER" style="-fx-padding: 10;">
        <Label text="ANAGNO DISPATCH SYSTEM V2" style="-fx-text-fill: #94A3B8; -fx-font-size: 9px; -fx-letter-spacing: 1px;" />
    </HBox>
</VBox>