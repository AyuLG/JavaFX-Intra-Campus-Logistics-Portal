<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="parentContainer" alignment="TOP_CENTER" prefHeight="700.0" prefWidth="420.0" style="-fx-background-color: #F1F5F9;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="anagno.controller.MerchantController">
    
    <stylesheets>
        <URL value="@login.css" />
    </stylesheets>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15 20 0 0;">
        <Button onAction="#handleMinimize" styleClass="window-control-button" text="—" />
        <Button onAction="#handleClose" styleClass="window-control-button, close-button" text="✕" />
    </HBox>

    <VBox spacing="20" style="-fx-padding: 10 30 30 30;" VBox.vgrow="ALWAYS">
        <children>
            <VBox alignment="CENTER_LEFT" spacing="5">
                <Label style="-fx-text-fill: #6366F1; -fx-font-size: 10; -fx-letter-spacing: 1.5px; -fx-font-weight: bold;" text="MERCHANT PORTAL" />
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="pageTitle" style="-fx-text-fill: #1E293B; -fx-font-size: 22; -fx-font-weight: bold;" text="Inventory Ledger" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#loadInventory" style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 8; -fx-font-size: 16; -fx-cursor: hand; -fx-pref-width: 40;" text="↻" />
                    </children>
                </HBox>
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="ALWAYS">
                <children>
                    <VBox spacing="8">
                        <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;" text="SEARCH INVENTORY" />
                        <TextField fx:id="searchField" promptText="Search by product name..." style="-fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" />
                    </VBox>

                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;" text="PRODUCT STOCK" />

                    <TableView fx:id="inventoryTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colName" prefWidth="180" text="PRODUCT NAME" />
                            <TableColumn fx:id="colStock" prefWidth="70" text="QTY" />
                            <TableColumn fx:id="colPrice" prefWidth="80" text="PRICE" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <VBox spacing="10">
                        <Button maxWidth="Infinity" onAction="#showAddProductPopup" prefHeight="50" 
                                style="-fx-font-weight: bold; -fx-background-color: #6366F1; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;" text="+ ADD NEW PRODUCT" />
                        
                        <HBox spacing="10">
                            <Button onAction="#handleDelete" prefHeight="40" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-border-color: #EF4444; -fx-text-fill: #EF4444; -fx-background-color: transparent; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Delete Item" />
                            
                            <Button onAction="#showMerchantBusinessSettings" prefHeight="40" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-border-color: #6366F1; -fx-text-fill: #6366F1; -fx-background-color: transparent; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Market Settings" />
                        </HBox>

                        <Button onAction="#showUserProfileSettings" maxWidth="Infinity"
                                style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-size: 11; -fx-cursor: hand;" text="⚙ Account Profile Settings" />
                    </VBox>
                </children>
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleLogout" prefHeight="45.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="LOGOUT " />
        </children>
    </VBox>

    <HBox alignment="CENTER" style="-fx-padding: 10;">
        <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 9px; -fx-letter-spacing: 1px;" text="ANAGNO MERCHANT SYSTEM V2" />
    </HBox>
</VBox>