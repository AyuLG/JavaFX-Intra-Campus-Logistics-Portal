<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="420.0" spacing="0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 20; -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-border-radius: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="anagno.controller.SettingsController">
    <children>
        <VBox spacing="5" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20 20 0 0; -fx-border-color: transparent transparent #E2E8F0 transparent;">
            <children>
                <Label style="-fx-text-fill: #6366F1; -fx-font-size: 10; -fx-letter-spacing: 1.5px; -fx-font-weight: bold;" text="SECURITY" />
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label style="-fx-text-fill: #1E293B; -fx-font-size: 22; -fx-font-weight: bold;" text="Account Settings" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleClose" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 35; -fx-pref-height: 35;" text="✕" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="20" style="-fx-padding: 30;">
            <children>
                <VBox spacing="15">
                    <children>
                        <VBox spacing="8">
                            <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;" text="CURRENT PASSWORD" />
                            <PasswordField fx:id="currentPasswordField" promptText="Verify current password" 
                                           style="-fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-color: white;" />
                        </VBox>

                        <VBox spacing="8">
                            <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;" text="NEW PASSWORD" />
                            <PasswordField fx:id="newPasswordField" promptText="Enter at least 8 characters" 
                                           style="-fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-color: white;" />
                        </VBox>
                    </children>
                </VBox>

                <Separator style="-fx-opacity: 0.4;" />

                <VBox spacing="12">
                    <children>
                        <Button maxWidth="Infinity" onAction="#handleSavePassword" prefHeight="45" 
                                style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="UPDATE PASSWORD" />
                        
                        <HBox alignment="CENTER" spacing="10">
                            <children>
                                <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-font-size: 12; -fx-cursor: hand;" text="Cancel and Close" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>