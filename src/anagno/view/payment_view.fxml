<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Line?>

<VBox fx:id="parentContainer" alignment="TOP_CENTER" prefHeight="700.0" prefWidth="420.0" 
      style="-fx-background-color: #F1F5F9;" xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="anagno.controller.PaymentController">
    
    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 15 20 0 0;">
        <Button onAction="#handleMinimize" style="-fx-background-color: transparent; -fx-text-fill: #94A3B8; -fx-cursor: hand;" text="—" />
        <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #EF4444; -fx-cursor: hand;" text="✕" />
    </HBox>

    <VBox spacing="25" VBox.vgrow="ALWAYS" style="-fx-padding: 20 35 30 35;">
        <children>
            <VBox spacing="5">
                <Button onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #6366F1; -fx-padding: 0; -fx-cursor: hand;" text="← Back to Menu" />
                <Label text="CHECKOUT" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="ORDER SUMMARY" style="-fx-font-size: 11; -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-letter-spacing: 1;" />
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="Subtotal" style="-fx-text-fill: #64748B;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="subtotalLabel" text="0.00 ETB" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" />
                </HBox>
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="Delivery Fee" style="-fx-text-fill: #64748B;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="15.00 ETB" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" />
                </HBox>

                <Line endX="310" stroke="#F1F5F9" />

                <HBox alignment="CENTER_LEFT">
                    <Label text="TOTAL TO PAY" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="finalTotalLabel" text="15.00 ETB" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #6366F1;" />
                </HBox>
            </VBox>

            <VBox spacing="12">
                <Label text="PAYMENT METHOD" style="-fx-font-size: 11; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" />
                
                <fx:define>
                    <ToggleGroup fx:id="paymentGroup" />
                </fx:define>
                
                <ToggleButton fx:id="telebirrBtn" toggleGroup="$paymentGroup" selected="true" maxWidth="Infinity" prefHeight="55" 
                              style="-fx-background-color: white; -fx-border-color: #6366F1; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" 
                              text="Telebirr" textFill="#1E293B" onAction="#handlePaymentSelection" />

                <ToggleButton fx:id="cbeBtn" toggleGroup="$paymentGroup" maxWidth="Infinity" prefHeight="55" 
                              style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" 
                              text="CBE Birr" textFill="#1E293B" onAction="#handlePaymentSelection" />
                
                <ToggleButton fx:id="cashBtn" toggleGroup="$paymentGroup" maxWidth="Infinity" prefHeight="55" 
                              style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" 
                              text="Cash on Delivery" textFill="#1E293B" onAction="#handlePaymentSelection" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button onAction="#handleConfirmOrder" maxWidth="Infinity" prefHeight="55.0" 
                    style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 12; -fx-cursor: hand;" 
                    text="CONFIRM ORDER" />
        </children>
    </VBox>
</VBox>